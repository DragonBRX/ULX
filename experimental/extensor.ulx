// Função auxiliar para contar parâmetros
funcao contar_parametros(extensor) {
    config = extensor.configuracao
    vocab = extensor.token_store.vocabulario
    oculto = config.tamanho_oculto
    intermediario = config.tamanho_intermediario
    camadas = config.camadas

    // Embeddings
    params = vocab * oculto * 2

    // Pesos das camadas
    params = params + camadas * (
        4 * oculto * oculto +           // Atenção Q, K, V, O
        2 * oculto * intermediario +   // FFN
        2 * oculto                     // LayerNorms
    )

    // Projeção de saída
    params = params + oculto * vocab

    retorna params
}
